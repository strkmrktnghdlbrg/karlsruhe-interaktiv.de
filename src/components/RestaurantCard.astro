---
import ContentImage from "./ContentImage.astro";
import type { Restaurant } from "../data/restaurants";
import { getDistrict } from "../data/districts";

interface Props { restaurant: Restaurant }
const { restaurant } = Astro.props;
const district = getDistrict(restaurant.district);
---

<a href={`/restaurants/${restaurant.slug}/`} class="card group block">
  <div class="aspect-[4/3] relative overflow-hidden">
    <ContentImage
      imgKey={restaurant.imageKey}
      fallbackHue={restaurant.imageHue}
      fallbackLabel={restaurant.name}
      imgClass="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <div class="absolute top-3 left-3">
      <span class="pill" style="background: rgba(8,9,10,0.85); backdrop-filter: blur(8px);">{restaurant.cuisine}</span>
    </div>
    <div class="absolute top-3 right-3">
      <span class="pill font-bold" style="background: rgba(8,9,10,0.85); backdrop-filter: blur(8px);">{restaurant.priceLevel}</span>
    </div>
  </div>
  <div class="p-3">
    <p class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">{district?.name ?? restaurant.district}</p>
    <h3 class="text-base font-semibold leading-tight mb-2" style="color: var(--color-text);">{restaurant.name}</h3>
    <p class="text-xs leading-relaxed line-clamp-2" style="color: var(--color-text-body);">{restaurant.shortDesc}</p>
  </div>
</a>
