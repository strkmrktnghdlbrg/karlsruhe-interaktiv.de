---
import { sightsByDistrict } from "../data/sights";
import { topHotelsByDistrict } from "../data/hotels";
import { restaurantsByDistrict } from "../data/restaurants";
import SightCard from "./SightCard.astro";
import HotelCard from "./HotelCard.astro";
import RestaurantCard from "./RestaurantCard.astro";

interface Props {
  district: string;
  excludeSlug?: string;
  type?: "sights" | "hotels" | "restaurants";
  title?: string;
}

const { district, excludeSlug, type = "sights", title } = Astro.props;

const sightItems = sightsByDistrict(district).filter((s) => s.slug !== excludeSlug).slice(0, 4);
const hotelItems = topHotelsByDistrict(district, 4).filter((h) => h.slug !== excludeSlug);
const restItems = restaurantsByDistrict(district).filter((r) => r.slug !== excludeSlug).slice(0, 4);

const heading = title ?? (
  type === "sights" ? "Weitere Sehenswuerdigkeiten im Bezirk" :
  type === "hotels" ? "Hotels im Bezirk" :
  "Restaurants im Bezirk"
);
---

<section class="py-12 border-t" style="border-color: var(--color-border);">
  <h2 class="text-2xl font-semibold tracking-tight mb-6" style="color: var(--color-text);">{heading}</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    {type === "sights" && sightItems.map((s) => <SightCard sight={s} />)}
    {type === "hotels" && hotelItems.map((h) => <HotelCard hotel={h} />)}
    {type === "restaurants" && restItems.map((r) => <RestaurantCard restaurant={r} />)}
  </div>
</section>
