---
import { Image } from "astro:assets";
import { city } from "../data/city";
import { districts } from "../data/districts";
import { categories } from "../data/categories";
import { features } from "../data/features";
import logo from "../assets/branding/logo.svg";

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t" style="background: var(--color-surface); border-color: var(--color-border);">
  <div class="container-page py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-flex mb-4" style="color: var(--color-accent);" aria-label="Zur Startseite">
          <Image src={logo} alt={`${city.name}-Interaktiv`} width={320} height={64} class="h-12 w-auto" />
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-body);">
          {city.description.short}
        </p>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest mb-4" style="color: var(--color-text);">Bezirke</h4>
        <ul class="space-y-2">
          {districts.slice(0, 8).map((d) => (
            <li>
              <a href={`/bezirke/${d.slug}/`} class="text-sm transition-colors" style="color: var(--color-text-muted);">{d.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest mb-4" style="color: var(--color-text);">Kategorien</h4>
        <ul class="space-y-2">
          {categories.slice(0, 8).map((c) => (
            <li>
              <a href={`/kategorien/${c.slug}/`} class="text-sm transition-colors" style="color: var(--color-text-muted);">{c.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest mb-4" style="color: var(--color-text);">Service</h4>
        <ul class="space-y-2">
          {features.werben.enabled && (
            <li><a href="/werben/" class="text-sm" style="color: var(--color-text-muted);">Werben</a></li>
          )}
          {features.reiseplaner.enabled && (
            <li><a href="/reiseplaner/" class="text-sm" style="color: var(--color-text-muted);">Reiseplaner</a></li>
          )}
          <li><a href="/kategorien/" class="text-sm" style="color: var(--color-text-muted);">Alle Kategorien</a></li>
          <li><a href="/events/" class="text-sm" style="color: var(--color-text-muted);">Events & Termine</a></li>
          {features.news.enabled && (
            <li><a href="/news/" class="text-sm" style="color: var(--color-text-muted);">News</a></li>
          )}
          <li><a href="/tech/" class="text-sm" style="color: var(--color-accent);">Tech-Hub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t flex flex-col md:flex-row items-start md:items-center justify-between gap-4" style="border-color: var(--color-border);">
      <p class="text-xs" style="color: var(--color-text-muted);">
        &copy; {year} {city.name}-Interaktiv. Inhalte unter Quellenangabe.
      </p>
      <div class="flex items-center gap-5">
        <a href="/impressum/" class="text-xs" style="color: var(--color-text-muted);">Impressum</a>
        <a href="/datenschutz/" class="text-xs" style="color: var(--color-text-muted);">Datenschutz</a>
        <a href="/agb/" class="text-xs" style="color: var(--color-text-muted);">AGB</a>
      </div>
    </div>
  </div>
</footer>
