---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import {
  streets,
  getStreet,
  getHerkunft,
  herkunftView,
  streetsByStadtteilNum,
  stadtteilSlugByName,
  editorialDistrict,
  STAND,
} from "../../data/strassen";
import { city } from "../../data/city";

export function getStaticPaths() {
  return streets.map((s) => ({ params: { strasse: s.slug } }));
}

const { strasse } = Astro.params;
const street = getStreet(strasse!)!;
const herkunft = getHerkunft(street);
const hv = herkunftView(street, herkunft);

const primaryStt = street.stadtteile[0];
const guide = primaryStt ? editorialDistrict(stadtteilSlugByName(primaryStt.name)) : undefined;

// Nachbarstraßen im (ersten) Stadtteil, um die aktuelle Straße herum.
const siblings = primaryStt
  ? streetsByStadtteilNum(primaryStt.num).filter((s) => s.slug !== street.slug)
  : [];
const idx = siblings.findIndex((s) => s.name > street.name);
const around =
  idx < 0 ? siblings.slice(-8) : siblings.slice(Math.max(0, idx - 4), idx + 4);

const stadtteileLabel = street.stadtteile.map((t) => t.name).join(", ");

const metaDesc =
  `${street.name} in Karlsruhe: Stadtteil ${stadtteileLabel || "Karlsruhe"}` +
  (hv ? `. Herkunft des Straßennamens und Einordnung im Überblick.` : `.`);

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Karlsruhe", item: `${city.domain}/` },
    { "@type": "ListItem", position: 2, name: "Straßenverzeichnis", item: `${city.domain}/strassenverzeichnis/` },
    ...(primaryStt
      ? [{ "@type": "ListItem", position: 3, name: primaryStt.name, item: `${city.domain}/strassenverzeichnis/stadtteil/${stadtteilSlugByName(primaryStt.name)}/` }]
      : []),
    { "@type": "ListItem", position: primaryStt ? 4 : 3, name: street.name },
  ],
};
---

<BaseLayout title={`${street.name} – Straße in Karlsruhe`} description={metaDesc}>
  <div class="container-page py-12">
    <Breadcrumbs
      items={[
        { label: "Start", href: "/" },
        { label: "Straßenverzeichnis", href: "/strassenverzeichnis/" },
        ...(primaryStt
          ? [{ label: primaryStt.name, href: `/strassenverzeichnis/stadtteil/${stadtteilSlugByName(primaryStt.name)}/` }]
          : []),
        { label: street.name },
      ]}
    />

    <div class="max-w-3xl mb-8">
      <p class="eyebrow mb-3">Straße in Karlsruhe</p>
      <h1 class="text-4xl sm:text-5xl font-medium tracking-tight mb-5" style="color: var(--color-text);">
        {street.name}
      </h1>
      <div class="flex flex-wrap gap-2">
        {street.stadtteile.map((t) => (
          <a href={`/strassenverzeichnis/stadtteil/${stadtteilSlugByName(t.name)}/`} class="pill" style="text-decoration: none;">
            {t.name}
          </a>
        ))}
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
      <div class="lg:col-span-2 space-y-10">
        {/* Namensherkunft */}
        {hv ? (
          <section>
            <h2 class="text-2xl sm:text-3xl font-semibold mb-4" style="color: var(--color-text);">
              Woher kommt der Name „{street.name}“?
            </h2>
            <p class="text-base leading-relaxed mb-5" style="color: var(--color-text-body);">
              {hv.lead}
            </p>
            <dl class="p-5 sm:p-6 space-y-3 border" style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);">
              <div class="flex flex-col sm:flex-row sm:gap-4">
                <dt class="text-xs font-semibold uppercase tracking-widest shrink-0 sm:w-44 pt-0.5" style="color: var(--color-text-subtle);">Einordnung</dt>
                <dd class="text-sm" style="color: var(--color-text-body);">{hv.katLabel}</dd>
              </div>
              {hv.person && (
                <div class="flex flex-col sm:flex-row sm:gap-4">
                  <dt class="text-xs font-semibold uppercase tracking-widest shrink-0 sm:w-44 pt-0.5" style="color: var(--color-text-subtle);">Namensgeber</dt>
                  <dd class="text-sm" style="color: var(--color-text-body);">{hv.person}{hv.lebensdaten ? ` (${hv.lebensdaten})` : ""}</dd>
                </div>
              )}
              {hv.benennung && (
                <div class="flex flex-col sm:flex-row sm:gap-4">
                  <dt class="text-xs font-semibold uppercase tracking-widest shrink-0 sm:w-44 pt-0.5" style="color: var(--color-text-subtle);">Benannt</dt>
                  <dd class="text-sm" style="color: var(--color-text-body);">{hv.benennung}</dd>
                </div>
              )}
              {hv.fruehereNamen && (
                <div class="flex flex-col sm:flex-row sm:gap-4">
                  <dt class="text-xs font-semibold uppercase tracking-widest shrink-0 sm:w-44 pt-0.5" style="color: var(--color-text-subtle);">Frühere Namen</dt>
                  <dd class="text-sm" style="color: var(--color-text-body);">{hv.fruehereNamen}</dd>
                </div>
              )}
            </dl>
            <p class="text-xs mt-4" style="color: var(--color-text-muted);">
              Die Angaben zur Namensherkunft geben Fakten aus dem Straßennamenbuch der Stadt
              Karlsruhe wieder. Ausführliche Erläuterungen bietet das offizielle Straßennamenbuch.
            </p>
          </section>
        ) : (
          <section>
            <h2 class="text-2xl sm:text-3xl font-semibold mb-4" style="color: var(--color-text);">
              {street.name}
            </h2>
            <p class="text-base leading-relaxed" style="color: var(--color-text-body);">
              Die {street.name} liegt im Stadtteil {stadtteileLabel || "Karlsruhe"}. Zur Herkunft
              des Straßennamens liegen in unserer Datenbasis keine dokumentierten Angaben vor.
            </p>
          </section>
        )}

        {/* Lage */}
        <section>
          <h2 class="text-2xl sm:text-3xl font-semibold mb-4" style="color: var(--color-text);">
            Lage in Karlsruhe
          </h2>
          <p class="text-base leading-relaxed" style="color: var(--color-text-body);">
            {street.crossesDistricts
              ? `Die ${street.name} verläuft durch mehrere Karlsruher Stadtteile: ${stadtteileLabel}.`
              : `Die ${street.name} liegt im Karlsruher Stadtteil ${stadtteileLabel || "Karlsruhe"}.`}
            {" "}Alle Straßen des Stadtteils findest du auf der jeweiligen Stadtteil-Seite.
          </p>
        </section>
      </div>

      {/* Sidebar */}
      <aside class="space-y-8">
        <div class="p-5 sm:p-6 border" style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);">
          <h2 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">
            Auf einen Blick
          </h2>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="font-semibold" style="color: var(--color-text);">Stadtteil</dt>
              <dd style="color: var(--color-text-body);">{stadtteileLabel || "Karlsruhe"}</dd>
            </div>
            {hv?.katLabel && (
              <div>
                <dt class="font-semibold" style="color: var(--color-text);">Namensherkunft</dt>
                <dd style="color: var(--color-text-body);">{hv.katLabel}</dd>
              </div>
            )}
            {hv?.benennung && (
              <div>
                <dt class="font-semibold" style="color: var(--color-text);">Benannt</dt>
                <dd style="color: var(--color-text-body);">{hv.benennung}</dd>
              </div>
            )}
          </dl>
        </div>

        {around.length > 0 && primaryStt && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-accent);">
              Straßen in {primaryStt.name}
            </h2>
            <ul class="space-y-1.5">
              {around.map((s) => (
                <li>
                  <a href={`/strassenverzeichnis/${s.slug}/`} class="text-sm link-accent">{s.name}</a>
                </li>
              ))}
            </ul>
            <a href={`/strassenverzeichnis/stadtteil/${stadtteilSlugByName(primaryStt.name)}/`} class="inline-block mt-3 text-sm font-semibold link-accent">
              Alle Straßen in {primaryStt.name} →
            </a>
          </div>
        )}

        {guide && primaryStt && (
          <a
            href={guide}
            class="block p-5 border transition-colors"
            style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);"
            onmouseover="this.style.borderColor='var(--color-accent)'"
            onmouseout="this.style.borderColor='var(--color-border)'"
          >
            <p class="font-semibold" style="color: var(--color-text);">
              Stadtteil-Guide: {primaryStt.name} →
            </p>
            <p class="text-sm mt-1" style="color: var(--color-text-muted);">
              Sehenswürdigkeiten, Hotels und Tipps im Stadtteil entdecken.
            </p>
          </a>
        )}
      </aside>
    </div>

    <p class="text-xs mt-12 pt-6 border-t max-w-3xl" style="border-color: var(--color-border); color: var(--color-text-muted);">
      Datenbasis: {STAND}. Straßengeometrie © OpenStreetMap-Mitwirkende (ODbL), aufbereitet vom
      OK Lab Karlsruhe (Code for Karlsruhe). Angaben zur Namensherkunft als Fakten aus dem
      Straßennamenbuch der Stadt Karlsruhe. Stadtteil-Zuordnung über die amtlichen
      Stadtteilgrenzen. Angaben ohne Gewähr.
    </p>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
</BaseLayout>
