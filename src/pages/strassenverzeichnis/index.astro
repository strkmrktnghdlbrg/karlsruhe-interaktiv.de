---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { streets, stadtteile, editorialDistrict, STAND } from "../../data/strassen";
import { city } from "../../data/city";

const totalStreets = streets.length;
const totalStadtteile = stadtteile.length;

const metaDesc =
  `Das Straßenverzeichnis für Karlsruhe: alle ${totalStreets} Straßen mit Stadtteil und ` +
  `der Herkunft des Straßennamens. Adresse suchen und Angaben auf einen Blick, ` +
  `dazu ${totalStadtteile} Stadtteile zum Stöbern.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Straßenverzeichnis Karlsruhe",
  description: metaDesc,
  isPartOf: { "@type": "WebSite", name: "Karlsruhe-Interaktiv", url: `${city.domain}/` },
};
---

<BaseLayout title="Straßenverzeichnis Karlsruhe" description={metaDesc}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{ label: "Start", href: "/" }, { label: "Straßenverzeichnis" }]} />

    <div class="max-w-3xl mb-10">
      <p class="eyebrow mb-3">Karlsruhe von A bis Z</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-5" style="color: var(--color-text);">
        Straßenverzeichnis Karlsruhe
      </h1>
      <p class="text-lg leading-relaxed" style="color: var(--color-text-body);">
        Alle <strong style="color: var(--color-text);">{totalStreets}</strong> Karlsruher Straßen auf einen Blick.
        Wähle eine Straße und du siehst den Stadtteil und, wo dokumentiert, die Herkunft des
        Straßennamens: nach wem oder was die Straße benannt ist und seit wann.
      </p>
    </div>

    {/* Adress-Zoom */}
    <div class="mb-14 p-5 sm:p-8 border" style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);">
      <label for="street-search" class="block text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-accent);">
        Straße oder Adresse suchen
      </label>
      <div class="relative">
        <input
          id="street-search"
          type="search"
          autocomplete="off"
          placeholder="z. B. Kaiserstraße, Marktplatz, Amalienstraße …"
          class="w-full px-4 py-3.5 text-base focus:outline-none focus:ring-2"
          style="background: var(--color-bg); color: var(--color-text); border: 1px solid var(--color-border); border-radius: var(--radius-input);"
          aria-controls="street-results"
          aria-expanded="false"
          role="combobox"
        />
        <ul
          id="street-results"
          role="listbox"
          class="hidden absolute z-20 mt-2 w-full max-h-80 overflow-y-auto"
          style="background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-card); box-shadow: var(--shadow-xl);"
        ></ul>
      </div>
      <p id="street-hint" class="text-sm mt-3" style="color: var(--color-text-muted);">
        Mindestens 2 Zeichen eingeben. {totalStreets} Straßen in {totalStadtteile} Stadtteilen.
      </p>
    </div>

    {/* Nach Stadtteil */}
    <section class="mb-12">
      <h2 class="text-3xl font-semibold mb-6" style="color: var(--color-text);">
        Nach Stadtteil stöbern
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {stadtteile.map((t) => {
          const guide = editorialDistrict(t.slug);
          return (
            <a
              href={`/strassenverzeichnis/stadtteil/${t.slug}/`}
              class="block p-5 border transition-colors"
              style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);"
              onmouseover="this.style.borderColor='var(--color-accent)'"
              onmouseout="this.style.borderColor='var(--color-border)'"
            >
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-text-subtle);">
                Stadtteil {t.num}
              </p>
              <p class="text-lg font-semibold" style="color: var(--color-text);">{t.name}</p>
              <p class="text-sm mt-1" style="color: var(--color-text-muted);">
                {t.streetCount} Straßen{guide ? " · mit Stadtteil-Guide" : ""}
              </p>
            </a>
          );
        })}
      </div>
    </section>

    <p class="text-xs pt-6 border-t max-w-3xl" style="border-color: var(--color-border); color: var(--color-text-muted);">
      Datenbasis: {STAND}. Straßengeometrie © OpenStreetMap-Mitwirkende (ODbL),
      aufbereitet vom OK Lab Karlsruhe (Code for Karlsruhe). Die Stadtteil-Zuordnung
      erfolgt über die amtlichen Stadtteilgrenzen. Angaben ohne Gewähr.
    </p>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />

  <script is:inline>
    (function () {
      var input = document.getElementById("street-search");
      var results = document.getElementById("street-results");
      if (!input || !results) return;

      var data = null;
      var loading = false;

      function norm(s) {
        return s
          .toLowerCase()
          .replace(/ä/g, "ae").replace(/ö/g, "oe").replace(/ü/g, "ue").replace(/ß/g, "ss")
          .normalize("NFKD").replace(/[^a-z0-9\s]/g, " ").replace(/\s+/g, " ").trim();
      }

      function load() {
        if (data || loading) return;
        loading = true;
        fetch("/strassenverzeichnis/strassen-index.json")
          .then(function (r) { return r.json(); })
          .then(function (j) { data = j; loading = false; render(); })
          .catch(function () { loading = false; });
      }

      function hide() {
        results.classList.add("hidden");
        input.setAttribute("aria-expanded", "false");
      }

      function render() {
        var q = norm(input.value);
        if (q.length < 2) { hide(); return; }
        if (!data) { load(); return; }
        var terms = q.split(" ");
        var out = [];
        for (var i = 0; i < data.length && out.length < 20; i++) {
          var k = data[i].k;
          var ok = true;
          for (var t = 0; t < terms.length; t++) {
            if (k.indexOf(terms[t]) === -1) { ok = false; break; }
          }
          if (ok) out.push(data[i]);
        }
        out.sort(function (a, b) {
          var as = a.k.indexOf(q) === 0 ? 0 : 1;
          var bs = b.k.indexOf(q) === 0 ? 0 : 1;
          if (as !== bs) return as - bs;
          return a.n.localeCompare(b.n, "de");
        });
        if (!out.length) {
          results.innerHTML =
            '<li class="px-4 py-3 text-sm" style="color: var(--color-text-muted);">Keine Straße gefunden.</li>';
          results.classList.remove("hidden");
          input.setAttribute("aria-expanded", "true");
          return;
        }
        var html = "";
        for (var j = 0; j < out.length; j++) {
          var e = out[j];
          html +=
            '<li role="option"><a href="/strassenverzeichnis/' + e.s + '/" ' +
            'class="block px-4 py-2.5 hover:bg-[var(--color-surface-input)]">' +
            '<span class="block text-sm font-semibold" style="color: var(--color-text);">' + e.n + "</span>" +
            '<span class="block text-xs" style="color: var(--color-text-muted);">' + e.t + "</span>" +
            "</a></li>";
        }
        results.innerHTML = html;
        results.classList.remove("hidden");
        input.setAttribute("aria-expanded", "true");
      }

      input.addEventListener("focus", load);
      input.addEventListener("input", render);
      document.addEventListener("click", function (e) {
        if (!results.contains(e.target) && e.target !== input) hide();
      });
      input.addEventListener("keydown", function (e) {
        if (e.key === "Escape") hide();
        if (e.key === "Enter") {
          var first = results.querySelector("a");
          if (first) window.location.href = first.getAttribute("href");
        }
      });
    })();
  </script>
</BaseLayout>
