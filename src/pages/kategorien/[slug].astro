---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SightCard from "../../components/SightCard.astro";
import RestaurantCard from "../../components/RestaurantCard.astro";
import GetYourGuideWidget from "../../components/GetYourGuideWidget.astro";
import { categories, getCategory } from "../../data/categories";
import { sightsByCategory } from "../../data/sights";
import { restaurantsByCategory } from "../../data/restaurants";
import { getGygPlacement } from "../../data/gyg";

export function getStaticPaths() {
  return categories
    .filter((c) => sightsByCategory(c.slug).length > 0 || restaurantsByCategory(c.slug).length > 0)
    .map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = getCategory(slug!);
if (!cat) return Astro.redirect("/404");
const cSights = sightsByCategory(cat.slug);
const cRest = restaurantsByCategory(cat.slug);
---

<BaseLayout title={cat.name} description={`${cat.name} in Karlsruhe: ${cat.shortDesc}`}>
  <div class="container-page py-12">
    <Breadcrumbs items={[
      {label: "Start", href: "/"},
      {label: "Kategorien", href: "/kategorien/"},
      {label: cat.name},
    ]} />
    <header class="mb-12">
      <p class="eyebrow mb-3">Kategorie</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">{cat.name} in Karlsruhe</h1>
      <p class="text-lg max-w-3xl" style="color: var(--color-text-body);">{cat.shortDesc}</p>
    </header>

    {cSights.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-6" style="color: var(--color-text);">Sehenswuerdigkeiten</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {cSights.map((s) => <SightCard sight={s} />)}
        </div>
      </section>
    )}

    {cRest.length > 0 && (
      <section>
        <h2 class="text-2xl font-semibold mb-6" style="color: var(--color-text);">Restaurants</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {cRest.map((r) => <RestaurantCard restaurant={r} />)}
        </div>
      </section>
    )}

    <GetYourGuideWidget placement={getGygPlacement(`category:${cat.slug}`)} />
  </div>
</BaseLayout>
