  .ha-surface strong { color: #20233a; font-weight: 700; }
  .ha-surface a { color: #365DA3; text-decoration: underline; text-underline-offset: 3px; }
  .ha-box { background: #f4f6fb; border: 1px solid #dde3f0; border-radius: 14px; padding: 22px 24px; margin: 28px 0; }
  .ha-box-title { font-size: 19px; font-weight: 800; color: #20233a; margin-bottom: 6px; }
  .ha-box-text { margin: 0; }
