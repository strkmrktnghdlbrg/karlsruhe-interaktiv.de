Options -Indexes

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

# ============================================================
# Bot-Block auf den Affiliate-Redirects (/r/)
# Bots folgen die 302 auf awin1.com; AWIN zaehlt JEDEN Hit als Klick.
# Messung 01.-23.07.2026: bis 66 % Klicks je GA4-Session, 5 Sales auf 2.052 Klicks.
# Greift NUR auf /r/ und /go/ (Outbound-Gate) - der Content bleibt fuer alle Crawler erreichbar,
# ein False-Positive kostet also hoechstens einen Partnerlink, nie Indexierung.
# ============================================================
RewriteCond %{HTTP_USER_AGENT} (crawl|spider|slurp|scraper|archiver|indexer) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (curl/|wget|python-|go-http|java/|okhttp|libwww|scrapy|axios|node-fetch|guzzle|httpclient) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (headlesschrome|phantomjs|puppeteer|playwright|selenium) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (zgrab|masscan|nmap|nikto|sqlmap|wpscan|censys|nuclei|acunetix|netsparker|qualys) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (googlebot|bingbot|yandexbot|duckduckbot|applebot|seznambot|exabot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (ahrefsbot|semrushbot|mj12bot|dotbot|blexbot|petalbot|seokicks|sistrix|serpstatbot|dataforseo|majestic|sitebulb|seobility|netcraft|screaming) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|oai-searchbot|ccbot|claudebot|claude-web|anthropic|perplexity|amazonbot|bytespider|meta-externalagent|google-extended|diffbot|omgili|timpibot|youbot|imagesift|cohere) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|pinterest|redditbot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} ^$
RewriteRule ^(r|go)/ - [F,L]

# ---- Affiliate-Redirects (/r/...) 302, clickref = karlsruhe-interaktiv.de (AWIN 514869) ----
RewriteRule ^r/docmorris(-10euro)?/?$ https://www.awin1.com/cread.php?s=2490784&v=14485&q=372737&r=514869&clickref=karlsruhe-interaktiv.de [R=302,L,NE]
RewriteRule ^r/shop-apotheke(-rezept)?/?$ https://www.awin1.com/cread.php?s=3450028&v=13808&q=471107&r=514869&clickref=karlsruhe-interaktiv.de [R=302,L,NE]
RewriteRule ^r/mediherz(-gutscheine)?/?$ https://www.awin1.com/cread.php?s=2269210&v=11630&q=348918&r=514869&clickref=karlsruhe-interaktiv.de [R=302,L,NE]
RewriteRule ^r/medpex(-zuzahlungsfrei)?/?$ https://www.awin1.com/awclick.php?gid=447437&mid=36320&awinaffid=514869&linkid=3237938&clickref=karlsruhe-interaktiv.de [R=302,L,NE]
RewriteRule ^r/fliegende-pillen/?$ https://t.adcell.com/p/click?promoId=120221&slotId=78194&subId=karlsruhe-interaktiv.de&param0=https://www.fliegende-pillen.de/ [R=302,L,NE]
RewriteRule ^r/parken-fliegen/?$ https://www.awin1.com/cread.php?awinmid=14793&awinaffid=514869&clickref=karlsruhe-interaktiv.de [R=302,L,NE]
  RewriteBase /

  # non-www → www
  RewriteCond %{HTTP_HOST} !^www\.karlsruhe-interaktiv\.de$ [NC]
  RewriteRule ^(.*)$ https://www.karlsruhe-interaktiv.de/$1 [L,R=301]

  # ===================================================================
  # 301-Weiterleitungen alter WordPress-URLs (Migration -> Astro)
  # Erhaelt Rankings/Backlinks und beseitigt 404-Fehler (GA4).
  # ===================================================================

  # --- Stadt-/Tourismus-Content auf das jeweilige neue Pendant ---
  RewriteRule ^schloss/?$ https://www.karlsruhe-interaktiv.de/sehenswuerdigkeiten/karlsruher-schloss/ [R=301,L]
  RewriteRule ^universitaet-kit/?$ https://www.karlsruhe-interaktiv.de/sehenswuerdigkeiten/kit-campus-sued/ [R=301,L]
  RewriteRule ^bundesgerichtshof/?$ https://www.karlsruhe-interaktiv.de/sehenswuerdigkeiten/bundesverfassungsgericht/ [R=301,L]
  RewriteRule ^hoftheater/?$ https://www.karlsruhe-interaktiv.de/sehenswuerdigkeiten/badisches-staatstheater/ [R=301,L]
  RewriteRule ^majolika-kunsthandwerk/?$ https://www.karlsruhe-interaktiv.de/sehenswuerdigkeiten/majolika-manufaktur/ [R=301,L]
  RewriteRule ^kunstszene/?$ https://www.karlsruhe-interaktiv.de/kategorien/kunst-medien/ [R=301,L]
  RewriteRule ^(museen|badische-landesbibliothek|badische-landesmuseum)/?$ https://www.karlsruhe-interaktiv.de/kategorien/museen/ [R=301,L]
  RewriteRule ^faecherstadt/?$ https://www.karlsruhe-interaktiv.de/ [R=301,L]
  RewriteRule ^ein-tag-in-karlsruhe-die-besten-aktivitaeten-fuer-einen-unvergesslichen-aufenthalt/?$ https://www.karlsruhe-interaktiv.de/reiseplaner/ [R=301,L]
  RewriteRule ^hotels-karlsruhe/?$ https://www.karlsruhe-interaktiv.de/hotels/ [R=301,L]
  RewriteRule ^hotels/hotels-in-karlsruhe[^/]*/?$ https://www.karlsruhe-interaktiv.de/hotels/ [R=301,L]

  # --- Geschichts-Artikel -> Kategorie "Historisches" ---
  RewriteRule ^(wichtige-historische-ereignisse|architektur|denkmaeler|18-jahrhundert|20-jahrhundert|industrialisierung|industriegeschichte|industrielle-revolution-19-jahrhundert|weimarer-republik|badische-revolution-1848-49|gruendung|beruehmte-persoenlichkeiten|juedisches-leben|archaeologische-funde|staedtebauliche-soziale-entwicklung|historische-feste-und-braeuche|historische-stadtfuehrungen|karlsruhes-beitrag-zur-deutschen-einigung-im-19-jahrhundert)/?$ https://www.karlsruhe-interaktiv.de/kategorien/historische-architektur/ [R=301,L]

  # --- Alte Blog-/Ratgeber-Artikel -> passende neue Branchenseite ---
  RewriteRule ^die-top-10-immobilienmakler-in-karlsruhe-expertenliste-2023/?$ https://www.karlsruhe-interaktiv.de/immobilienmakler-karlsruhe/ [R=301,L]
  RewriteRule ^(hochzeitsfotograf-karlsruhe-vergleich-preise|so-findest-du-den-passenden-hochzeitsfotograf-fuer-dich-in-karlsruhe)/?$ https://www.karlsruhe-interaktiv.de/fotografen-karlsruhe/ [R=301,L]
  RewriteRule ^(die-ideale-werbeagentur|werbeagentur-beratung)/?$ https://www.karlsruhe-interaktiv.de/marketingagenturen-karlsruhe/ [R=301,L]
  RewriteRule ^seo-agenturen-in-karlsruhe(/.*)?$ https://www.karlsruhe-interaktiv.de/marketingagenturen-karlsruhe/ [R=301,L]

  # --- WordPress-Duplikat-Slugs (-2) -> kanonische Branchenseite ---
  RewriteRule ^anlageberater-karlsruhe-2/?$ https://www.karlsruhe-interaktiv.de/anlageberater-karlsruhe/ [R=301,L]
  RewriteRule ^bestatter-karlsruhe-2/?$ https://www.karlsruhe-interaktiv.de/bestatter-karlsruhe/ [R=301,L]
  RewriteRule ^energieberater-karlsruhe-2/?$ https://www.karlsruhe-interaktiv.de/energieberater-karlsruhe/ [R=301,L]
  RewriteRule ^gebaudereiniger-karlsruhe-2/?$ https://www.karlsruhe-interaktiv.de/gebaudereiniger-karlsruhe/ [R=301,L]
  RewriteRule ^spediteure-karlsruhe-2/?$ https://www.karlsruhe-interaktiv.de/spediteure-karlsruhe/ [R=301,L]

  # --- WordPress-Taxonomie-Archive (spezifische zuerst, dann generisch) ---
  RewriteRule ^thema/inka-online(/.*)?$ https://www.karlsruhe-interaktiv.de/events/ [R=301,L]
  RewriteRule ^thema/leben-in-karlsruhe(/.*)?$ https://www.karlsruhe-interaktiv.de/bezirke/ [R=301,L]
  RewriteRule ^category/ https://www.karlsruhe-interaktiv.de/ [R=301,L]
  RewriteRule ^thema/ https://www.karlsruhe-interaktiv.de/ [R=301,L]

  # Serve pre-built HTML files directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L,QSA]
</IfModule>
